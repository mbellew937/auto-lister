# Required. Server-side only. Never put this in frontend code or commit .env.
GEMINI_API_KEY=

# Optional model override. The app defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Self-host default. On first launch, visit /setup to create the first local admin.
AUTO_MARKETPLACE_AUTH_PROVIDER=local

# Public attribution and hosted-offer links shown on the login page.
AUTO_MARKETPLACE_CREDIT_LABEL=MRB Technologies
AUTO_MARKETPLACE_CREDIT_URL=https://mrbtechnologies.com
AUTO_MARKETPLACE_HOSTED_URL=https://marketplace.mrbtechnologies.com
# Dollar signs need quotes if this file is sourced by a shell.
AUTO_MARKETPLACE_HOSTED_COMPARE_AT_PRICE='$5'
AUTO_MARKETPLACE_HOSTED_PRICE='$1'
AUTO_MARKETPLACE_FREE_SIGNUP_LIMIT=25
AUTO_MARKETPLACE_FREE_POSTS=3
# Public package/source links shown on the self-host setup page.
AUTO_MARKETPLACE_PACKAGE_DOWNLOAD_URL=https://marketplace.mrbtechnologies.com/downloads/auto-lister-self-host.tar.gz
AUTO_MARKETPLACE_PUBLIC_REPO_URL=https://github.com/mbellew937/auto-lister.git
# Optional donation handles shown on the self-host setup page.
AUTO_MARKETPLACE_CASHAPP_HANDLE='$michaelbellew'
AUTO_MARKETPLACE_VENMO_HANDLE=@mikebellew
# Optional support links shown on /support and in the app UI.
AUTO_MARKETPLACE_SUPPORT_EMAIL=support@mrbtechnologies.com
AUTO_MARKETPLACE_SUPPORT_URL=
AUTO_MARKETPLACE_SUPPORT_HELPDESK_URL=https://helpdesk.mrbtechnologies.com
AUTO_MARKETPLACE_SUPPORT_GITHUB_ISSUES_URL=https://github.com/mbellew937/auto-lister/issues

# Optional Matomo analytics. Leave blank to disable analytics.
MATOMO_URL=
MATOMO_SITE_ID=

# Optional AI fallback. Gemini remains the primary analyzer; OpenAI is used
# when Gemini is unavailable or returns an analysis error.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional BYO Stripe settings for self-hosters who want to charge their own users.
# The core app does not require Stripe. Keep these server-side only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=https://your-domain.example.com/dashboard
STRIPE_CANCEL_URL=https://your-domain.example.com/
